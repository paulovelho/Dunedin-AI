RewriteEngine On

# remove for enabling folder indexes:
Options -Indexes

<Files ".user.ini">
  Require all denied
</Files>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # uncomment for enabling folder navigation
  # RewriteCond %{REQUEST_FILENAME} -d [OR]
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule .+ - [L]

  # Strip /api/v1/ prefix and split into magrathea_{control,action,params}
  RewriteRule ^api/v1/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/(.*)$ index.php?magrathea_control=$1&magrathea_action=$2&magrathea_params=$3 [QSA,L]
  RewriteRule ^api/v1/([a-zA-Z0-9_-]+)/(.*)$ index.php?magrathea_control=$1&magrathea_action=$2 [QSA,L]
  RewriteRule ^api/v1/(.*)$ index.php?magrathea_control=$1 [QSA,L]
  SetEnvIf Authorization .+ HTTP_AUTHORIZATION=$0

</IfModule>
