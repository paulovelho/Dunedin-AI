{
    "name": "dunedin-ai/api",
    "description": "Dunedin AI highlights API",
    "type": "project",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mysqli": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "platypustechnology/magratheaphp2": "dev-master",
        "kreait/firebase-php": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "./"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
